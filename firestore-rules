rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Regler för de officiella matcherna (Bara Karl får ändra)
    match /matches/{matchId} {
      allow read: if request.auth != null && request.auth.token.email.matches('.*@nyamunken[.]se') && !request.auth.token.email.matches('qq.*');
      allow write: if request.auth != null && (request.auth.token.email == 'karl.tornered@nyamunken.se' || request.auth.token.email == 'jonas.waltelius@nyamunken.se');
    }
    
    // Tillåt listning av användare (krävs för statistik-sidan)
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.token.email.matches('.*@nyamunken[.]se') && !request.auth.token.email.matches('qq.*');
    }

    // Regler för användarnas tipsrader
    match /users/{userId}/tips/{tipId} {
      // Alla inloggade kollegor får läsa varandras tips (krävs för leaderboards/statistik)
      allow read: if request.auth != null && request.auth.token.email.matches('.*@nyamunken[.]se') && !request.auth.token.email.matches('qq.*');

      // Du får BARA skriva/spara tips på ditt EGET ID (request.auth.uid == userId)
      allow write: if request.auth != null && request.auth.uid == userId && !request.auth.token.email.matches('qq.*');
    }
    
  }
}
