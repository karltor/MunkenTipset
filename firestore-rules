rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'karl.tornered@nyamunken.se' ||
        request.auth.token.email == 'jonas.waltelius@nyamunken.se'
      );
    }

    function isValidUser() {
      return request.auth != null &&
        request.auth.token.email.matches('.*@nyamunken[.]se') &&
        !request.auth.token.email.matches('qq.*') &&
        !request.auth.token.email.matches('.*[0-9]{3}.*@.*');
    }

    // Officiella matcher + admin-inställningar (Karl & Jonas får skriva)
    match /matches/{matchId} {
      allow read: if isValidUser();
      allow write: if isAdmin();
    }

    // Tillåt listning av användare + skapa eget dokument vid inloggning
    // Admins kan skriva till alla användare (för testverktyg)
    match /users/{userId} {
      allow read: if isValidUser();
      allow write: if (isValidUser() && request.auth.uid == userId) || isAdmin();
    }

    // Regler för användarnas tipsrader
    // Admins kan skriva till alla (för testverktyg)
    match /users/{userId}/tips/{tipId} {
      allow read: if isValidUser();
      allow write: if (isValidUser() && request.auth.uid == userId) || isAdmin();
    }

    // Livechatt — alla kan läsa, alla kan skriva meddelanden, bara admins kan skriva _meta
    match /chat/{docId} {
      allow read: if isValidUser();
      allow write: if docId == '_meta' ? isAdmin() : isValidUser();
    }

  }
}
